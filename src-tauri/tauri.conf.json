{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TraceForge",
  "version": "0.1.3",
  "identifier": "com.wt.reverse.toolkit",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "login",
        "title": "TraceForge Login",
        "width": 560,
        "height": 560,
        "center": true,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "visible": true
      },
      {
        "label": "main",
        "title": "TraceForge Workbench",
        "width": 1280,
        "height": 850,
        "center": true,
        "minWidth": 1100,
        "minHeight": 750,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}