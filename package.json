{
    "name":  "lumo-coding",
    "private":  true,
    "version":  "0.1.1",
    "type":  "module",
    "scripts":  {
                    "dev":  "vite",
                    "build":  "tsc -b \u0026\u0026 vite build",
                    "lint":  "eslint .",
                    "preview":  "vite preview",
                    "verify:crypto:parity":  "npx vite-node --script scripts/test-parity.ts",
                    "verify:crypto:preview":  "npx vite-node --script scripts/verify-crypto-preview.ts",
                    "verify:crypto:export":  "npx vite-node --script scripts/verify-export-artifacts.ts",
                    "verify:crypto:validation":  "npx vite-node --script scripts/verify-crypto-validation.ts",
                    "verify:crypto:easy-language":  "npx vite-node --script scripts/verify-easy-language-matrix.ts",
                    "verify:crypto:scriptcontrol":  "npx vite-node --script scripts/verify-scriptcontrol-smoke.ts",
                    "verify:crypto:all":  "npm run verify:crypto:preview \u0026\u0026 npm run verify:crypto:export \u0026\u0026 npm run verify:crypto:validation \u0026\u0026 npm run verify:crypto:easy-language \u0026\u0026 npm run verify:crypto:scriptcontrol",
                    "verify:agent:guardrails":  "npx vite-node --script scripts/verify-agent-guardrails.ts",
                    "verify:agent:permissions":  "npx vite-node --script scripts/verify-agent-permissions.ts",
                    "verify:agent:commands":  "npx vite-node --script scripts/verify-agent-commands.ts",
                    "verify:agent:persistence":  "npx vite-node --script scripts/verify-thread-persistence-runtime.ts",
                    "updater:publish":  "powershell -ExecutionPolicy Bypass -File scripts/publish-updater.ps1",
                    "updater:publish:flat":  "powershell -ExecutionPolicy Bypass -File scripts/publish-updater.ps1 -FlatLayout",
                    "tauri":  "npx tauri",
                    "tauri:dev":  "npx tauri dev",
                    "tauri:build":  "npx tauri build",
                    "tauri:build:oneclick":  "powershell -ExecutionPolicy Bypass -File scripts/build-tauri-signed.ps1",
                    "tauri:release":  "powershell -ExecutionPolicy Bypass -File scripts/release-tauri.ps1",
                    "tauri:release:patch":  "powershell -ExecutionPolicy Bypass -File scripts/release-tauri.ps1 -BumpPatch",
                    "tauri:release:publish":  "powershell -ExecutionPolicy Bypass -File scripts/release-and-publish.ps1",
                    "tauri:release:publish:patch":  "powershell -ExecutionPolicy Bypass -File scripts/release-and-publish.ps1 -BumpPatch"
                },
