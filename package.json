{
  "name": "traceforge-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "verify:crypto:parity": "npx vite-node --script scripts/test-parity.ts",
    "verify:crypto:preview": "npx vite-node --script scripts/verify-crypto-preview.ts",
    "verify:crypto:export": "npx vite-node --script scripts/verify-export-artifacts.ts",
    "verify:crypto:validation": "npx vite-node --script scripts/verify-crypto-validation.ts",
    "verify:crypto:easy-language": "npx vite-node --script scripts/verify-easy-language-matrix.ts",
    "verify:crypto:scriptcontrol": "npx vite-node --script scripts/verify-scriptcontrol-smoke.ts",
    "verify:crypto:all": "npm run verify:crypto:preview && npm run verify:crypto:export && npm run verify:crypto:validation && npm run verify:crypto:easy-language && npm run verify:crypto:scriptcontrol",
    "reverse:sync": "powershell -ExecutionPolicy Bypass -File scripts/sync-reverse-integrations.ps1",
    "reverse:camoufox:mcp": "powershell -ExecutionPolicy Bypass -Command \"$env:PYTHONPATH='integrations/camoufox-reverse-mcp/src'; python -m camoufox_reverse_mcp\"",
    "tauri": "npx tauri",
    "tauri:dev": "npx tauri dev",
    "tauri:build": "npx tauri build"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
